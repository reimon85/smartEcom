# ============================================
# SmartEcom AI Pipeline - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- PostgreSQL ---
POSTGRES_USER=smartecom
POSTGRES_PASSWORD=smartecom_secret
POSTGRES_DB=smartecom
DATABASE_URL=postgresql://smartecom:smartecom_secret@localhost:5432/smartecom

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your-access-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret
SHOPIFY_API_VERSION=2024-01

# --- API Server ---
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3001

# --- Next.js Dashboard ---
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- n8n ---
N8N_USER=admin
N8N_PASSWORD=admin123

# --- Email Notifications (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
ALERT_EMAIL_TO=alerts@yourstore.com

# --- Slack Notifications (optional) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# --- Pricing (gpt-4o-mini as of 2024) ---
# Input:  $0.00015 per 1K tokens
# Output: $0.0006  per 1K tokens
OPENAI_INPUT_COST_PER_1K=0.00015
OPENAI_OUTPUT_COST_PER_1K=0.0006
